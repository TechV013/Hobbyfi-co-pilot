# Required: PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Required: Strong random secret for JWT signing (generate via: openssl rand -hex 32)
JWT_SECRET="change-this-to-a-random-secret"

# Optional
PORT=4000
NODE_ENV=development
REDIS_URL=""
ALLOWED_ORIGINS=http://localhost:3000
