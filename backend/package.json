{
  "name": "@hobbyfi/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx prisma generate --no-hints && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "npx prisma generate --schema=prisma/schema.sqlite.prisma --no-hints && tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "test": "npm run test:smoke && npm run test:vitest",
    "test:vitest": "vitest run",
    "test:smoke": "npx prisma generate --schema=prisma/schema.sqlite.prisma && tsx src/scripts/run-tests.ts",
    "vercel-build": "npx prisma generate",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "generate-token": "tsx src/scripts/generate-token.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/swagger-ui-express": "^4.1.8",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "express": "^4.21.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.14.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "openapi-types": "^12.1.3",
    "prettier": "^3.9.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.0"
  }
}
